{
  "nodes": [
    {
      "id": "ccbot_project",
      "type": "project",
      "label": "ccbot",
      "properties": {
        "summary": "Telegram Bot for monitoring Claude Code sessions via tmux",
        "language": "Python",
        "version": "0.1.0"
      }
    },
    {
      "id": "env_example",
      "type": "config",
      "label": ".env.example",
      "properties": {
        "path": ".env.example",
        "summary": "Environment variable template for bot configuration",
        "vars_defined": ["TELEGRAM_BOT_TOKEN", "ALLOWED_USERS", "TMUX_SESSION_NAME", "CLAUDE_COMMAND", "MONITOR_POLL_INTERVAL"]
      }
    },
    {
      "id": "pyproject",
      "type": "config",
      "label": "pyproject.toml",
      "properties": {
        "path": "pyproject.toml",
        "summary": "Python project configuration",
        "dependencies": ["python-telegram-bot[rate-limiter]>=21.0", "python-dotenv>=1.0.0", "httpx>=0.27.0", "libtmux>=0.37.0", "Pillow>=10.0.0", "aiofiles>=24.0.0", "telegramify-markdown>=0.5.0,<1.0.0"],
        "dev_dependencies": ["pyright>=1.1.0", "pytest>=8.0", "pytest-asyncio>=0.24.0", "pytest-cov>=6.0", "ruff>=0.8.0"],
        "entry_point": "ccbot.main:main",
        "build_system": "hatchling"
      }
    },
    {
      "id": "AGENTS",
      "type": "document",
      "label": "AGENTS.md",
      "properties": {
        "path": "AGENTS.md",
        "summary": "Agent instructions for AI coding workflows — Codex variant",
        "audience": "Codex AI agent",
        "language": "en",
        "tech_stack": ["Python", "python-telegram-bot", "tmux", "uv"]
      }
    },
    {
      "id": "CLAUDE_MD",
      "type": "document",
      "label": "CLAUDE.md",
      "properties": {
        "path": "CLAUDE.md",
        "summary": "Claude Code project knowledge file (CLAUDE.md)",
        "audience": "Claude Code AI",
        "language": "en",
        "tech_stack": ["Python", "python-telegram-bot", "tmux", "uv"]
      }
    },
    {
      "id": "README_EN",
      "type": "document",
      "label": "README.md",
      "properties": {
        "path": "README.md",
        "summary": "Main project documentation (English)",
        "language": "en",
        "sections": ["Why CCBot", "Features", "Prerequisites", "Installation", "Configuration", "Hook Setup", "Usage", "Topic Workflow", "Message History", "Notifications", "Running in tmux", "Data Storage", "File Structure", "Contributors"]
      }
    },
    {
      "id": "README_CN",
      "type": "document",
      "label": "README_CN.md",
      "properties": {
        "path": "README_CN.md",
        "summary": "Chinese translation of README",
        "language": "zh"
      }
    },
    {
      "id": "README_RU",
      "type": "document",
      "label": "README_RU.md",
      "properties": {
        "path": "README_RU.md",
        "summary": "Russian translation of README",
        "language": "ru"
      }
    },
    {
      "id": "concept_one_to_one",
      "type": "concept",
      "label": "1 Topic = 1 Window = 1 Session",
      "properties": {
        "summary": "Core routing model: each Telegram forum topic maps to exactly one tmux window and one Claude Code session, keyed by tmux window ID (@0, @12)"
      }
    },
    {
      "id": "concept_hook_tracking",
      "type": "concept",
      "label": "Hook-based Session Tracking",
      "properties": {
        "summary": "SessionStart hook writes session_map.json; monitor polls it to detect session changes across restarts"
      }
    },
    {
      "id": "concept_message_queue",
      "type": "concept",
      "label": "Message Queue",
      "properties": {
        "summary": "Per-user FIFO message queue with merging (3800 char limit) and tool_use/tool_result pairing"
      }
    },
    {
      "id": "concept_rate_limiting",
      "type": "concept",
      "label": "Rate Limiting",
      "properties": {
        "summary": "AIORateLimiter(max_retries=5) on the Application (30/s global); pre-filled bucket on restart to avoid Telegram server burst"
      }
    },
    {
      "id": "concept_formatting",
      "type": "concept",
      "label": "Message Formatting",
      "properties": {
        "summary": "HTML via chatgpt-md-converter with plain text fallback; no runtime switch to MarkdownV2; HTML-aware splitting for long messages"
      }
    },
    {
      "id": "concept_inline_ui",
      "type": "concept",
      "label": "Inline Keyboard UI",
      "properties": {
        "summary": "Interactive inline keyboards for AskUserQuestion, ExitPlanMode, Permission Prompts; callback data under 64 bytes"
      }
    },
    {
      "id": "concept_state",
      "type": "concept",
      "label": "State Persistence",
      "properties": {
        "summary": "state.json (thread bindings), session_map.json (hook-generated), monitor_state.json (byte offsets) — survive restarts"
      }
    },
    {
      "id": "concept_voice",
      "type": "concept",
      "label": "Voice Transcription",
      "properties": {
        "summary": "Voice messages transcribed via OpenAI API and forwarded as text to Claude Code"
      }
    },
    {
      "id": "concept_telegram",
      "type": "concept",
      "label": "Telegram Bot Integration",
      "properties": {
        "summary": "python-telegram-bot based bot operating in Telegram Forum (topics) mode; command handlers and topic routing"
      }
    },
    {
      "id": "concept_tmux",
      "type": "concept",
      "label": "tmux Integration",
      "properties": {
        "summary": "Window management via libtmux; all internal routing keyed by tmux window ID; window names as display labels"
      }
    },
    {
      "id": "concept_claude",
      "type": "concept",
      "label": "Claude Code Integration",
      "properties": {
        "summary": "Bridges Claude Code CLI sessions running in tmux to Telegram topics; reads output and sends keystrokes"
      }
    },
    {
      "id": "concept_monitoring",
      "type": "concept",
      "label": "Session Monitoring",
      "properties": {
        "summary": "Polls JSONL transcript files every 2s; detects and notifies on assistant responses, thinking content, tool use/result, and local command output"
      }
    },
    {
      "id": "concept_directory",
      "type": "concept",
      "label": "Directory Browser",
      "properties": {
        "summary": "Inline keyboard UI for browsing project directories and resuming or creating new Claude sessions"
      }
    },
    {
      "id": "concept_screenshot",
      "type": "concept",
      "label": "Terminal Screenshot",
      "properties": {
        "summary": "Captures terminal text as PNG image with ANSI color support using bundled fonts"
      }
    },
    {
      "id": "concept_auth",
      "type": "concept",
      "label": "User Authorization",
      "properties": {
        "summary": "Comma-separated ALLOWED_USERS env var; only authorized Telegram user IDs can interact with the bot"
      }
    },
    {
      "id": "concept_install",
      "type": "concept",
      "label": "Installation Methods",
      "properties": {
        "summary": "Install via uv tool, pipx from GitHub, or source clone with uv sync"
      }
    },
    {
      "id": "concept_config_system",
      "type": "concept",
      "label": "Configuration System",
      "properties": {
        "summary": "Config directory ~/.ccbot/ (overridable via CCBOT_DIR); .env loading priority: local .env > config dir .env"
      }
    }
  ],
