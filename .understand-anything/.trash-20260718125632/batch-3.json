      "id": "file:.agentic/prompts/analyze.md",
      "type": "node",
      "labels": ["document", "markdown", "prompt", "stage-definition"],
      "properties": {
        "path": ".agentic/prompts/analyze.md",
        "fileName": "analyze.md",
        "language": "markdown",
        "sizeLines": 28,
        "fileCategory": "docs",
        "stage": "ANALYZE",
        "pipelinePosition": 1,
        "summary": "Prompt for the ANALYZE stage: read-only analysis of the ccbot codebase using knowledge graph and source tree, producing a structured analysis report. Cross-checks backlog tasks against current code reality and identifies hotspots (complexity, fan-in/fan-out, untested files).",
        "inputs": [
          ".understand-anything/knowledge-graph.json",
          ".agentic/backlog/tasks.json",
          ".agentic/config.json",
          "AGENTS.md",
          "CLAUDE.md",
          ".claude/rules/*"
        ],
        "outputs": [
          ".agentic/out/analysis-report.json",
          ".agentic/out/analysis-report.md"
        ],
        "rules": "Read-only for src/ and tests/; prefer evidence from graph + file sizes; flag partially-done backlog tasks."
      }
    },
    {
      "id": "file:.agentic/prompts/plan.md",
      "type": "node",
      "labels": ["document", "markdown", "prompt", "stage-definition"],
      "properties": {
        "path": ".agentic/prompts/plan.md",
        "fileName": "plan.md",
        "language": "markdown",
        "sizeLines": 31,
        "fileCategory": "docs",
        "stage": "PLAN",
        "pipelinePosition": 2,
        "summary": "Prompt for the PLAN stage: turns analysis + backlog into an executable plan. Ranks ready tasks by priority, dependencies, and graph hotspots; selects one next task; expands acceptance criteria into a concrete implementation checklist.",
        "inputs": [
          ".agentic/out/analysis-report.json",
          ".agentic/backlog/tasks.json",
          ".agentic/policies.json"
        ],
        "outputs": [
          ".agentic/out/plan.json",
          ".agentic/out/plan.md",
          ".agentic/out/selected-task.json"
        ],
        "selectionRules": [
          "Never pick a task whose depends_on are incomplete",
          "Prefer status: ready over planned",
          "Prefer high priority + high graph signal",
          "Skip tasks covered by open agentic PRs",
          "Default: one task per implementation run"
        ]
      }
    },
    {
      "id": "file:.agentic/prompts/implement.md",
      "type": "node",
      "labels": ["document", "markdown", "prompt", "stage-definition"],
      "properties": {
        "path": ".agentic/prompts/implement.md",
        "fileName": "implement.md",
        "language": "markdown",
        "sizeLines": 47,
        "fileCategory": "docs",
        "stage": "IMPLEMENT",
        "pipelinePosition": 3,
        "summary": "Prompt for the IMPLEMENT stage: implements exactly one refactoring task using explore-design-implement-test-commit flow. Includes quality gates (ruff, pyright, pytest) and hard constraints against scope creep, force-pushing, or weakening auth/topic architecture.",
        "inputs": [
          ".agentic/out/selected-task.json",
          ".agentic/policies.json",
          "AGENTS.md",
          "CLAUDE.md"
        ],
        "outputs": [
          ".agentic/out/blocked.md"
        ],
        "qualityGates": [
          "uv sync --all-extras",
          "ruff check",
          "ruff format",
          "pyright src/ccbot/",
          "pytest --tb=short -q"
        ],
        "hardConstraints": [
          "Do not implement multiple backlog tasks in one PR",
          "Do not force-push or alter main directly",
          "Do not weaken auth, topic-only architecture, or CI gates"
        ]
      }
    },
    {
      "id": "file:.agentic/prompts/pr-body.md",
      "type": "node",
      "labels": ["document", "markdown", "prompt", "template"],
      "properties": {
        "path": ".agentic/prompts/pr-body.md",
        "fileName": "pr-body.md",
        "language": "markdown",
        "sizeLines": 35,
        "fileCategory": "docs",
        "templateType": "PR body",
        "summary": "GitHub PR body template for agentic refactoring PRs. Includes task metadata table, problem/solution sections, acceptance criteria checklist, validation gates, risk notes, and agent notes. Uses mustache-style {{PLACEHOLDER}} variables for dynamic content.",
        "placeholders": [
          "TASK_ID",
          "PRIORITY",
          "GRAPH_COMMIT",
          "PROBLEM",
          "SOLUTION",
          "ACCEPTANCE_CHECKLIST",
          "RISK",
          "AGENT_NOTES"
        ],
        "validationGates": [
          "ruff check / ruff format --check",
          "pyright",
          "pytest",
          "Manual reasoning: topic-only + auth invariants preserved"
        ]
      }
    },
    {
      "id": "file:.agentic/prompts/review.md",
      "type": "node",
      "labels": ["document", "markdown", "prompt", "stage-definition"],
      "properties": {
        "path": ".agentic/prompts/review.md",
        "fileName": "review.md",
        "language": "markdown",
        "sizeLines": 24,
        "fileCategory": "docs",
        "stage": "REVIEW",
        "pipelinePosition": 4,
        "summary": "Prompt for the REVIEW stage: reviews agentic PRs as a senior Python engineer. Focuses on correctness vs task/acceptance criteria, architecture constraints, concurrency/error-handling regressions, test adequacy, and scope creep. Outputs structured review with verdict.",
        "outputFormat": ["Summary", "Must-fix", "Should-fix", "Nits", "Verdict"],
        "focusAreas": [
          "Correctness vs task id and acceptance criteria",
          "Architecture constraints from AGENTS.md / CLAUDE.md",
          "Concurrency and error-handling regressions",
          "Test adequacy",
          "Scope creep beyond single task"
        ],
        "antiPatterns": [
          "Rewriting the PR in review-only mode",
          "Approving if quality gates fail or auth/topic constraints violated"
        ]
      }
    }
