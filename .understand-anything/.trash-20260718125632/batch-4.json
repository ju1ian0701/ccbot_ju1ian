      "id": "document:.claude/rules/architecture.md",
      "type": "document",
      "label": "System Architecture",
      "properties": {
        "filePath": ".claude/rules/architecture.md",
        "language": "markdown",
        "sizeLines": 102,
        "category": "docs",
        "summary": "High-level system architecture covering the Telegram bot module layout, handler modules, state files, and key design decisions including topic-centric routing, window ID-centric state, hook-based session tracking, tool_use↔tool_result pairing, MarkdownV2 with fallback, and startup re-resolution."
      }
    },
    {
      "id": "document:.claude/rules/message-handling.md",
      "type": "document",
      "label": "Message Handling Architecture",
      "properties": {
        "filePath": ".claude/rules/message-handling.md",
        "language": "markdown",
        "sizeLines": 41,
        "category": "docs",
        "summary": "Per-user message queue architecture with FIFO ordering, content/status merging, rate limiting via AIORateLimiter, mtime cache for poll efficiency, byte-offset incremental reads, and no-truncation policy at parse layer."
      }
    },
    {
      "id": "document:.claude/rules/topic-architecture.md",
      "type": "document",
      "label": "Topic-Only Architecture",
      "properties": {
        "filePath": ".claude/rules/topic-architecture.md",
        "language": "markdown",
        "sizeLines": 73,
        "category": "docs",
        "summary": "Exclusive Telegram Forum (topics) mode architecture defining 1 Topic = 1 Window = 1 Session mapping, thread_bindings (Topic→WindowID), session_map.json (WindowID→SessionID), message flows for outbound/inbound/new/resume sessions, topic lifecycle, and session lifecycle cleanup."
      }
    },
